{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "app.py": {
      "excludeFiles": "{api/**,__pycache__/**,backend/**/__pycache__/**,**/*.pyc,backend/.env,vercel/**}"
    }
  },
  "routes": [
    { "src": "/api", "dest": "/app.py" },
    { "src": "/api/(.*)", "dest": "/app.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
